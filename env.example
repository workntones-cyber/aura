# ── AI モード ──────────────────────────────────────
# personal : Groq API を使用（クラウド処理）
# business : faster-whisper を使用（完全ローカル処理）
AI_MODE=personal

# ── Groq API キー ───────────────────────────────────
# 個人用モードで使用します。
# 取得先: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── 録音ソース ──────────────────────────────────────
# mic    : マイク入力（対面会議・会議室向け）
# system : システム音声（オンライン会議向け）
#          Windows: 追加設定不要
#          Mac: BlackHole のインストールが必要
RECORDING_SOURCE=mic

# ── Windows 警告抑制 ────────────────────────────────
HF_HUB_DISABLE_SYMLINKS_WARNING=1
